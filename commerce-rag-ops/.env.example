# Real OpenAI-compatible LLM endpoint.
# Keep the API key in your local shell or private deployment secret store.
COMMERCE_RAG_LLM_ENDPOINT=https://opencode.ai/zen/go/v1
COMMERCE_RAG_LLM_MODEL=deepseek-v4-flash
COMMERCE_RAG_LLM_TIMEOUT=120
COMMERCE_RAG_LLM_RETRIES=3
COMMERCE_RAG_LLM_API_KEY=

# Strong local retrieval profile for GPU demos.
COMMERCE_RAG_RERANKER_MODEL=BAAI/bge-reranker-large
COMMERCE_RAG_RERANKER_DEVICE=cuda
COMMERCE_RAG_RERANKER_BATCH_SIZE=16

# Optional mirror for downloading Hugging Face models in restricted networks.
HF_ENDPOINT=https://hf-mirror.com
